{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/graphql",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/webapp/client/build/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/scrape?key=default_key",
      "schedule": "0 0 * * *"
    }
  ]
}
