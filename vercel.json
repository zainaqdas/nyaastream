{
  "version": 2,
  "outputDirectory": "webapp/client/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/graphql",
      "destination": "/api/index.js"
    },
    {
      "source": "/static/(.*)",
      "destination": "/webapp/client/build/static/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/webapp/client/build/favicon.ico"
    },
    {
      "source": "/manifest.json",
      "destination": "/webapp/client/build/manifest.json"
    },
    {
      "source": "/logo(.*)",
      "destination": "/webapp/client/build/logo$1"
    },
    {
      "source": "/(.*)",
      "destination": "/webapp/client/build/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/scrape?key=default_key",
      "schedule": "0 0 * * *"
    }
  ]
}
